# توکن رباتی که از @BotFather گرفتی
BOT_TOKEN=123456:ABC-DEF...

# آدرس عمومی سرور برای webhook (روی Railway خودش ست میشه با RAILWAY_PUBLIC_DOMAIN، نیازی به دستکاری نیست)
# اگر خواستی دستی بدی: WEBHOOK_URL=https://your-app.up.railway.app
WEBHOOK_URL=

# روی Railway وقتی Postgres plugin اضافه کنی این متغیر خودکار ساخته و لینک میشه
DATABASE_URL=postgres://user:pass@host:5432/dbname

# اطلاعات ورود پنل مدیریت - حتما تغییرشون بده
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# یک رشته تصادفی و طولانی برای امنیت سشن
SESSION_SECRET=change-this-to-a-long-random-string

# پورت (روی Railway خودش ست میشه)
PORT=3000

# فقط برای اجرای لوکال روی سیستم خودت (بدون webhook) این رو true بذار
USE_POLLING=false
